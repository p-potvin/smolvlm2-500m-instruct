# Example Nginx reverse-proxy config for a VPS gateway.
#
# Intent:
# - VPS terminates TLS for your public API domain (e.g., api.vaultwares.ca)
# - VPS forwards traffic to your local API host over your Tailscale tailnet
# - VPS injects a shared secret header so the API can reject bypass traffic
# - VPS is the choke-point for rate limits and emergency blocks
#
# Requirements:
# - Tailscale installed on VPS and joined to your tailnet
# - Local API reachable from the VPS over Tailscale (use the PC's Tailscale IP or MagicDNS name)
# - Let's Encrypt (or other ACME) certs installed on the VPS
# - API host configured to trust this VPS as a proxy (set TRUSTED_PROXY_CIDRS=100.73.57.6/32,... on the API host)
#
# NOTE:
# - Replace placeholders: <API_DOMAIN>, <LOCAL_API_TAILSCALE_IP>, <GATEWAY_SHARED_SECRET>
# - Keep the upstream HTTP over Tailscale unless you explicitly run TLS on the local API.

limit_req_zone $binary_remote_addr zone=vw_api_rl:10m rate=10r/s;

server {
    listen 80;
    server_name <API_DOMAIN>;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name <API_DOMAIN>;

    # Typical Let's Encrypt paths (adjust for your distro/ACME client)
    ssl_certificate     /etc/letsencrypt/live/<API_DOMAIN>/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/<API_DOMAIN>/privkey.pem;

    # Keep this strict. Your clients will always connect to the VPS via HTTPS.
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Basic abuse controls at the edge (still keep API-side rate limits enabled too).
    limit_req zone=vw_api_rl burst=60 nodelay;

    location / {
        proxy_pass http://<LOCAL_API_TAILSCALE_IP>:9001;

        # Preserve caller + protocol details for app-side enforcement/logging.
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Real-IP $remote_addr;

        # Gateway secret injection (API can require this for non-Tailscale public sources).
        proxy_set_header X-VW-Gateway-Secret <GATEWAY_SHARED_SECRET>;

        # Reasonable timeouts for long-running requests (adjust as needed).
        proxy_connect_timeout 10s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;
    }
}
